@using SkillSnap.Client.Models
@using SkillSnap.Client.Services
@inject ProjectService ProjectService
@inject NotificationService NotificationService

<section class="api-item-list">
    <h3>Items From API</h3>
    <p class="api-subtitle">Quick read-only snapshot from `/api/projects`.</p>

    @if (isLoading)
    {
        <p>Loading items...</p>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <ErrorBanner Message="@errorMessage" />
    }
    else if (items.Count == 0)
    {
        <p class="sample-note">No items found. Displaying sample entries.</p>
        <ul>
            <li>
                <strong>Sample: Learning Journal</strong><br />
                <span>A weekly digest of feature work and lessons learned.</span>
            </li>
            <li>
                <strong>Sample: Team Pulse Board</strong><br />
                <span>Tracks sprint highlights, blockers, and confidence trends.</span>
            </li>
        </ul>
    }
    else
    {
        <ul>
            @foreach (var item in items)
            {
                <li>
                    <strong>@item.Title</strong><br />
                    <span>@item.Description</span>
                </li>
            }
        </ul>
    }
</section>

@code {
    private List<Project> items = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await ProjectService.GetProjectsAsync();
        }
        catch (HttpRequestException ex)
        {
            errorMessage = ex.Message;
            NotificationService.ShowError(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .api-subtitle {
        color: #4d5964;
        margin-bottom: 0.85rem;
        font-size: 0.92rem;
    }

    .sample-note {
        margin-bottom: 0.45rem;
        font-size: 0.9rem;
        color: #6f7a84;
    }

    .api-item-list ul {
        padding-left: 1rem;
        margin: 0;
    }

    .api-item-list li {
        margin-bottom: 0.75rem;
        color: #36434d;
        font-size: 0.95rem;
    }

    .api-item-list li span {
        color: #56636f;
    }
</style>
