<article class="profile-card">
    <img src="@ImageUrl" alt="@($"{Name} profile image")" class="profile-image" />
    <h2>@Name</h2>
    <p>@Bio</p>
</article>

@code {
    [Parameter]
    public string Name { get; set; } = "Jordan Developer";

    [Parameter]
    public string Bio { get; set; } = "Full-stack developer passionate about building practical apps, learning new technologies, and improving developer workflows.";

    [Parameter]
    public string ImageUrl { get; set; } = "https://via.placeholder.com/160";
}

<style>
    .profile-card {
        max-width: 420px;
        padding: 1rem;
        border: 1px solid #d1d5db;
        border-radius: 0.75rem;
        background-color: #f8fafc;
    }

    .profile-image {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border-radius: 50%;
        display: block;
        margin-bottom: 0.75rem;
    }
</style>
