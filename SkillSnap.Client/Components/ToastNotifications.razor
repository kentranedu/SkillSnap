@implements IDisposable
@inject SkillSnap.Client.Services.NotificationService NotificationService

@if (isVisible)
{
    <div class="toast-container">
        <div class="toast @toastClass" role="status">@message</div>
    </div>
}

@code {
    private string message = string.Empty;
    private string toastClass = "toast-info";
    private bool isVisible;

    protected override void OnInitialized()
    {
        NotificationService.OnNotify += HandleNotify;
    }

    private void HandleNotify(SkillSnap.Client.Services.ToastLevel level, string notificationMessage)
    {
        message = notificationMessage;
        toastClass = level switch
        {
            SkillSnap.Client.Services.ToastLevel.Success => "toast-success",
            SkillSnap.Client.Services.ToastLevel.Warning => "toast-warning",
            SkillSnap.Client.Services.ToastLevel.Error => "toast-error",
            _ => "toast-info"
        };

        isVisible = true;
        StateHasChanged();
        _ = HideAfterDelayAsync();
    }

    private async Task HideAfterDelayAsync()
    {
        await Task.Delay(3000);
        isVisible = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NotificationService.OnNotify -= HandleNotify;
    }
}

<style>
    .toast-container {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 1000;
    }

    .toast {
        min-width: 260px;
        max-width: 380px;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
        font-weight: 600;
        background-color: #f8fafc;
    }

    .toast-info {
        border-color: #93c5fd;
        color: #1e3a8a;
    }

    .toast-success {
        border-color: #86efac;
        color: #166534;
    }

    .toast-warning {
        border-color: #fde68a;
        color: #92400e;
    }

    .toast-error {
        border-color: #fca5a5;
        color: #991b1b;
    }
</style>
